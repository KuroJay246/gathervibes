{
  "name": "gather-savor-event-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests scripts e2e eslint.config.js vite.config.js playwright.config.js",
    "test": "node --test tests/*.test.js",
    "doctor": "react-doctor . --project . --scope full --blocking none --no-telemetry",
    "doctor:changed": "react-doctor . --project . --scope changed --base main --blocking error --no-telemetry",
    "doctor:json": "react-doctor . --project . --scope full --blocking none --json --json-compact --no-telemetry",
    "product:copy-scan": "node scripts/product/copyScan.mjs",
    "product:routes": "node scripts/product/routeInventory.mjs",
    "product:bundle": "node scripts/product/bundleSummary.mjs",
    "product:docs": "node scripts/product/documentationCheck.mjs",
    "product:legacy": "node scripts/product/legacyControlCheck.mjs",
    "product:qa": "node scripts/product/runProductCommand.mjs qa",
    "product:audit": "node scripts/product/runProductCommand.mjs audit",
    "e2e:smoke": "npx -y firebase-tools@14.19.0 emulators:exec --only auth,firestore --project gathervibeshub \"playwright test --project=chromium e2e/navigation.spec.js\"",
    "e2e:full": "npx -y firebase-tools@14.19.0 emulators:exec --only auth,firestore --project gathervibeshub \"playwright test --project=chromium\"",
    "e2e:firefox": "npx -y firebase-tools@14.19.0 emulators:exec --only auth,firestore --project gathervibeshub \"playwright test --project=firefox\"",
    "e2e:webkit": "npx -y firebase-tools@14.19.0 emulators:exec --only auth,firestore --project gathervibeshub \"playwright test --project=webkit\"",
    "admin:ensure-access": "node scripts/admin/ensureAccessControl.mjs",
    "admin:verify-firebase": "node scripts/admin/verifyFirebaseSetup.mjs",
    "admin:ensure-codex-test-event": "node scripts/admin/ensureCodexTestEvent.mjs",
    "admin:verify-production-fixtures": "node scripts/admin/verifyProductionFixtures.mjs",
    "admin:verify-production-counts": "node scripts/admin/verifyProductionCounts.mjs",
    "admin:cpb-production-apply": "node scripts/admin/runCpbProductionApply.mjs",
    "firebase:deploy-rules": "npx firebase-tools deploy --only firestore:rules,firestore:indexes --project gathervibeshub",
    "firebase:deploy-hosting": "npx firebase-tools deploy --only hosting --project gathervibeshub",
    "firebase:deploy-all": "npx firebase-tools deploy --only firestore:rules,firestore:indexes,hosting --project gathervibeshub"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "firebase": "^12.6.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.25.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "read-excel-file": "^9.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^14.0.0",
    "globals": "^16.5.0",
    "react-doctor": "0.8.3",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
