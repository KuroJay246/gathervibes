rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Gather & Savor data model
    // ===============================================================
    // settings/accessControl
    //   approvedEmails: list<string> (created only in Firebase Console)
    //
    // events/{eventId}
    //   eventId: string (immutable, must equal document ID)
    //   eventName: string (1..150)
    //   eventDate: timestamp
    //   location: string (1..250)
    //   eventType: supported enum
    //   status: supported enum
    //   capacity: int (1..100000)
    //   ticketPrice: number (0..1000000)  — backward-compat scalar
    //   priceTiers: list<map> or null
    //     { name: string, price: number>=0, status: enum }
    //   notes: string (0..10000)
    //   createdAt: timestamp (immutable)
    //   updatedAt: timestamp
    //
    // registrations/{registrationId}
    //   buyerName: string|null
    //   attendeeNames: list<string> (optional, max 100)
    //   ticketCode: string|null
    //   ticketAssignedAt: timestamp|null
    //   ticketAssignedBy: string|null
    //   checkedInBy: string|null
    //
    // auditLogs/{logId}
    //   append-only event/registration audit record created in the same batch.

    function isSignedIn() {
      return request.auth != null;
    }

    function isApprovedAdmin() {
      return isSignedIn()
        && request.auth.token.email is string
        && exists(/databases/$(database)/documents/settings/accessControl)
        && get(/databases/$(database)/documents/settings/accessControl).data.approvedEmails is list
        && request.auth.token.email.lower() in
          get(/databases/$(database)/documents/settings/accessControl).data.approvedEmails;
    }

    function validShortId(value) {
      return value is string && value.size() > 0 && value.size() <= 128;
    }

    function validOptionalString(value, maxLength) {
      return value == null || value == '' || (value is string && value.size() <= maxLength);
    }

    function validOptionalAttendeeNames(value) {
      return value == null || (value is list && value.size() <= 100);
    }

    function validOptionalMoney(value) {
      return value == null || (value is number && value >= 0 && value <= 1000000);
    }

    function validOptionalPaymentMethod(value) {
      return value == null || value in [
        'firstpay', 'bank-transfer', 'cash', 'door', 'card', 'complimentary', 'unknown'
      ];
    }

    function validPerformedBy(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 256
        && (
          value == request.auth.token.email
          || (request.auth.uid != null && value == request.auth.uid)
        );
    }

    // ── Price tier validation ──────────────────────────────────────────────
    // Each tier must have: name (supported enum), price (number >= 0), and
    // status (supported enum). Rules do not support loops, so each allowed
    // list size is checked explicitly up to MAX_PRICE_TIERS (7).

    function validPriceTier(tier) {
      return tier is map
        && tier.keys().hasAll(['name', 'price', 'status'])
        && tier.keys().hasOnly(['name', 'price', 'status'])
        && tier.name in [
          'Early Bird', 'General', 'Door', 'Tier 1', 'Tier 2', 'Tier 3', 'Complimentary'
        ]
        && tier.price is number
        && tier.price >= 0
        && tier.price <= 1000000
        && tier.status in ['active', 'sold-out', 'hidden'];
    }

    function validPriceTiers(tiers) {
      return tiers == null
        || (
          tiers is list
          && tiers.size() <= 7
          && (
            tiers.size() == 0
            || (tiers.size() == 1 && validPriceTier(tiers[0]))
            || (tiers.size() == 2 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]))
            || (tiers.size() == 3 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]) && validPriceTier(tiers[2]))
            || (tiers.size() == 4 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]) && validPriceTier(tiers[2]) && validPriceTier(tiers[3]))
            || (tiers.size() == 5 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]) && validPriceTier(tiers[2]) && validPriceTier(tiers[3]) && validPriceTier(tiers[4]))
            || (tiers.size() == 6 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]) && validPriceTier(tiers[2]) && validPriceTier(tiers[3]) && validPriceTier(tiers[4]) && validPriceTier(tiers[5]))
            || (tiers.size() == 7 && validPriceTier(tiers[0]) && validPriceTier(tiers[1]) && validPriceTier(tiers[2]) && validPriceTier(tiers[3]) && validPriceTier(tiers[4]) && validPriceTier(tiers[5]) && validPriceTier(tiers[6]))
          )
        );
    }

    // ── Event allowed keys with optional priceTiers ────────────────────────
    function isValidEvent(data, eventId) {
      return (
          // Must have all required keys
          data.keys().hasAll([
            'eventId', 'eventName', 'eventDate', 'location', 'eventType',
            'status', 'capacity', 'ticketPrice', 'notes', 'createdAt', 'updatedAt'
          ])
          // May optionally include priceTiers
          && data.keys().hasOnly([
            'eventId', 'eventName', 'eventDate', 'location', 'eventType',
            'status', 'capacity', 'ticketPrice', 'notes', 'createdAt', 'updatedAt',
            'priceTiers'
          ])
          && data.eventId == eventId
          && validShortId(data.eventId)
          && data.eventName is string
          && data.eventName.size() > 0
          && data.eventName.size() <= 150
          && data.eventDate is timestamp
          && data.location is string
          && data.location.size() > 0
          && data.location.size() <= 250
          && data.eventType in [
            'cake-picnic', 'brunch', 'tasting', 'vendor-pop-up',
            'private-food-experience', 'other'
          ]
          && data.status in ['draft', 'upcoming', 'active', 'completed', 'cancelled']
          && data.capacity is int
          && data.capacity > 0
          && data.capacity <= 100000
          && data.ticketPrice is number
          && data.ticketPrice >= 0
          && data.ticketPrice <= 1000000
          && data.notes is string
          && data.notes.size() <= 10000
          && data.createdAt is timestamp
          && data.updatedAt is timestamp
          // Optional price tiers
          && (!('priceTiers' in data) || validPriceTiers(data.priceTiers))
        );
    }

    function isValidRegistration(data, registrationId) {
      return data.keys().hasAll([
          'registrationId', 'eventId', 'fullName', 'email', 'phone',
          'groupName', 'personsAttending', 'paymentStatus', 'paymentReference',
          'ticketStatus', 'ticketCode', 'ticketAssignedAt', 'ticketAssignedBy',
          'notes', 'checkedIn', 'checkInTime', 'checkedInBy', 'source', 'sourceRowId', 'timestamp',
          'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'registrationId', 'eventId', 'fullName', 'email', 'phone',
          'buyerName', 'attendeeNames',
          'groupName', 'personsAttending', 'paymentStatus', 'paymentReference',
          'priceTier', 'ticketPrice', 'amountDue', 'amountPaid', 'balanceDue', 'paymentMethod',
          'ticketStatus', 'ticketCode', 'ticketAssignedAt', 'ticketAssignedBy',
          'notes', 'checkedIn', 'checkInTime', 'checkedInBy', 'source', 'sourceRowId', 'timestamp',
          'createdAt', 'updatedAt'
        ])
        && data.registrationId == registrationId
        && validShortId(data.registrationId)
        && validShortId(data.eventId)
        && data.fullName is string
        && data.fullName.size() > 0
        && data.fullName.size() <= 250
        && (!('buyerName' in data) || validOptionalString(data.buyerName, 250))
        && (!('attendeeNames' in data) || validOptionalAttendeeNames(data.attendeeNames))
        && validOptionalString(data.email, 320)
        && validOptionalString(data.phone, 32)
        && validOptionalString(data.groupName, 250)
        && data.personsAttending is int
        && data.personsAttending >= 1
        && data.personsAttending <= 100
        && data.paymentStatus in ['paid', 'pending', 'complimentary', 'door', 'door-list', 'unknown']
        && (!('priceTier' in data) || validOptionalString(data.priceTier, 100))
        && (!('ticketPrice' in data) || validOptionalMoney(data.ticketPrice))
        && (!('amountDue' in data) || validOptionalMoney(data.amountDue))
        && (!('amountPaid' in data) || validOptionalMoney(data.amountPaid))
        && (!('balanceDue' in data) || validOptionalMoney(data.balanceDue))
        && (!('paymentMethod' in data) || validOptionalPaymentMethod(data.paymentMethod))
        && validOptionalString(data.paymentReference, 250)
        && data.ticketStatus in ['no-ticket-assigned', 'partially-assigned', 'assigned']
        && validOptionalString(data.ticketCode, 32)
        && (data.ticketAssignedAt == null || data.ticketAssignedAt is timestamp)
        && validOptionalString(data.ticketAssignedBy, 256)
        && data.notes is string
        && data.notes.size() <= 10000
        && data.checkedIn is bool
        && (data.checkInTime == null || data.checkInTime is timestamp)
        && validOptionalString(data.checkedInBy, 256)
        && data.source in ['manual', 'csv-import']
        && validOptionalString(data.sourceRowId, 128)
        && (data.timestamp == null || data.timestamp is timestamp)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidEventAuditLog(data, logId) {
      return data.keys().hasAll([
          'logId', 'eventId', 'action', 'targetType', 'targetId',
          'performedBy', 'timestamp', 'details'
        ])
        && data.keys().hasOnly([
          'logId', 'eventId', 'action', 'targetType', 'targetId',
          'performedBy', 'timestamp', 'details'
        ])
        && data.logId == logId
        && validShortId(data.logId)
        && validShortId(data.eventId)
        && data.action in ['event.create', 'event.update', 'event.delete']
        && data.targetType == 'event'
        && data.targetId == data.eventId
        && validPerformedBy(data.performedBy)
        && data.timestamp == request.time
        && data.details is map
        && data.details.keys().hasOnly(['eventName'])
        && data.details.eventName is string
        && data.details.eventName.size() > 0
        && data.details.eventName.size() <= 150;
    }

    function isValidRegistrationAuditLog(data, logId) {
      return data.keys().hasAll([
          'logId', 'eventId', 'action', 'targetType', 'targetId',
          'performedBy', 'timestamp', 'details'
        ])
        && data.keys().hasOnly([
          'logId', 'eventId', 'action', 'targetType', 'targetId',
          'performedBy', 'timestamp', 'details'
        ])
        && data.logId == logId
        && validShortId(data.logId)
        && validShortId(data.eventId)
        && data.action in [
          'registration.create', 'registration.update', 'registration.delete', 'registration.import',
          'registration.finance-update',
          'ticket.assign', 'ticket.unassign', 'ticket.regenerate',
          'checkin.complete', 'checkin.undo', 'checkin.duplicate-attempt'
        ]
        && data.targetType == 'registration'
        && validShortId(data.targetId)
        && validPerformedBy(data.performedBy)
        && data.timestamp == request.time
        && data.details is map;
    }

    function matchesEventMutation(data) {
      return (
          data.action == 'event.create'
          && !exists(/databases/$(database)/documents/events/$(data.eventId))
          && existsAfter(/databases/$(database)/documents/events/$(data.eventId))
          && getAfter(/databases/$(database)/documents/events/$(data.eventId)).data.eventName
            == data.details.eventName
        ) || (
          data.action == 'event.update'
          && exists(/databases/$(database)/documents/events/$(data.eventId))
          && existsAfter(/databases/$(database)/documents/events/$(data.eventId))
          && getAfter(/databases/$(database)/documents/events/$(data.eventId)).data.eventName
            == data.details.eventName
        ) || (
          data.action == 'event.delete'
          && exists(/databases/$(database)/documents/events/$(data.eventId))
          && !existsAfter(/databases/$(database)/documents/events/$(data.eventId))
          && get(/databases/$(database)/documents/events/$(data.eventId)).data.eventName
            == data.details.eventName
        );
    }

    function matchesRegistrationMutation(data) {
      return (
        data.targetType == 'registration'
        && (
          (
            data.action in ['registration.create', 'registration.import']
            && !exists(/databases/$(database)/documents/registrations/$(data.targetId))
            && existsAfter(/databases/$(database)/documents/registrations/$(data.targetId))
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
          ) || (
            data.action == 'checkin.complete'
            && exists(/databases/$(database)/documents/registrations/$(data.targetId))
            && existsAfter(/databases/$(database)/documents/registrations/$(data.targetId))
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedIn == false
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkInTime == null
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedIn == true
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkInTime == data.timestamp
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedInBy == data.performedBy
          ) || (
            data.action == 'checkin.undo'
            && exists(/databases/$(database)/documents/registrations/$(data.targetId))
            && existsAfter(/databases/$(database)/documents/registrations/$(data.targetId))
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedIn == true
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkInTime is timestamp
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedIn == false
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkInTime == null
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedInBy == null
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.updatedAt == data.timestamp
          ) || (
            data.action in [
              'registration.update', 'ticket.assign', 'ticket.unassign',
              'ticket.regenerate', 'registration.finance-update'
            ]
            && exists(/databases/$(database)/documents/registrations/$(data.targetId))
            && existsAfter(/databases/$(database)/documents/registrations/$(data.targetId))
            && getAfter(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
          ) || (
            data.action == 'registration.delete'
            && exists(/databases/$(database)/documents/registrations/$(data.targetId))
            && !existsAfter(/databases/$(database)/documents/registrations/$(data.targetId))
            && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
          )
        )
      );
    }

    function matchesDuplicateCheckInAttempt(data) {
      return data.action == 'checkin.duplicate-attempt'
        && exists(/databases/$(database)/documents/registrations/$(data.targetId))
        && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.eventId == data.eventId
        && get(/databases/$(database)/documents/registrations/$(data.targetId)).data.checkedIn == true;
    }

    function registrationIdentityUnchanged() {
      return request.resource.data.registrationId == resource.data.registrationId
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.source == resource.data.source
        && request.resource.data.sourceRowId == resource.data.sourceRowId
        && request.resource.data.timestamp == resource.data.timestamp
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function registrationDetailsUnchanged() {
      return registrationIdentityUnchanged()
        && request.resource.data.fullName == resource.data.fullName
        && request.resource.data.email == resource.data.email
        && request.resource.data.phone == resource.data.phone
        && (!('buyerName' in request.resource.data) || !('buyerName' in resource.data) || request.resource.data.buyerName == resource.data.buyerName)
        && (!('attendeeNames' in request.resource.data) || !('attendeeNames' in resource.data) || request.resource.data.attendeeNames == resource.data.attendeeNames)
        && request.resource.data.groupName == resource.data.groupName
        && request.resource.data.personsAttending == resource.data.personsAttending
        && request.resource.data.paymentStatus == resource.data.paymentStatus
        && request.resource.data.get('priceTier', null) == resource.data.get('priceTier', null)
        && request.resource.data.get('ticketPrice', null) == resource.data.get('ticketPrice', null)
        && request.resource.data.get('amountDue', null) == resource.data.get('amountDue', null)
        && request.resource.data.get('amountPaid', null) == resource.data.get('amountPaid', null)
        && request.resource.data.get('balanceDue', null) == resource.data.get('balanceDue', null)
        && request.resource.data.get('paymentMethod', null) == resource.data.get('paymentMethod', null)
        && request.resource.data.paymentReference == resource.data.paymentReference
        && request.resource.data.notes == resource.data.notes;
    }

    function ticketFieldsUnchanged() {
      return request.resource.data.ticketStatus == resource.data.ticketStatus
        && request.resource.data.ticketCode == resource.data.ticketCode
        && request.resource.data.ticketAssignedAt == resource.data.ticketAssignedAt
        && request.resource.data.ticketAssignedBy == resource.data.ticketAssignedBy;
    }

    function checkInFieldsUnchanged() {
      return request.resource.data.checkedIn == resource.data.checkedIn
        && request.resource.data.checkInTime == resource.data.checkInTime
        && request.resource.data.checkedInBy == resource.data.checkedInBy;
    }

    function hasNoTicketAssigned(data) {
      return data.ticketStatus == 'no-ticket-assigned'
        && data.ticketCode == null
        && data.ticketAssignedAt == null
        && data.ticketAssignedBy == null;
    }

    function hasImportedTicketCode(data) {
      return data.ticketStatus == 'assigned'
        && data.ticketCode is string
        && data.ticketCode.size() > 0
        && data.ticketCode.size() <= 32
        && data.ticketAssignedAt == null
        && data.ticketAssignedBy == null;
    }

    function isRegistrationDetailsUpdate() {
      return registrationIdentityUnchanged()
        && ticketFieldsUnchanged()
        && checkInFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullName', 'buyerName', 'attendeeNames', 'email', 'phone',
          'groupName', 'personsAttending', 'paymentStatus', 'paymentReference',
          'priceTier', 'ticketPrice', 'amountDue', 'amountPaid', 'balanceDue', 'paymentMethod',
          'notes', 'updatedAt'
        ]);
    }

    function isTicketAssignmentUpdate() {
      return registrationDetailsUnchanged()
        && checkInFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'ticketStatus', 'ticketCode', 'ticketAssignedAt', 'ticketAssignedBy', 'updatedAt'
        ])
        && request.resource.data.ticketStatus == 'assigned'
        && request.resource.data.ticketCode is string
        && request.resource.data.ticketCode.size() > 0
        && request.resource.data.ticketCode.size() <= 32
        && request.resource.data.ticketAssignedAt == request.time
        && validPerformedBy(request.resource.data.ticketAssignedBy);
    }

    function isTicketUnassignmentUpdate() {
      return registrationDetailsUnchanged()
        && checkInFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'ticketStatus', 'ticketCode', 'ticketAssignedAt', 'ticketAssignedBy', 'updatedAt'
        ])
        && resource.data.ticketStatus == 'assigned'
        && request.resource.data.ticketStatus == 'no-ticket-assigned'
        && request.resource.data.ticketCode == null
        && request.resource.data.ticketAssignedAt == null
        && request.resource.data.ticketAssignedBy == null;
    }

    function checkInCompletionChangedKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'checkedIn', 'checkInTime', 'checkedInBy', 'updatedAt'
      ]);
    }

    function isCheckInCompletionUpdate(registrationId) {
      return checkInCompletionChangedKeysOnly()
        && request.resource.data.registrationId == registrationId
        && request.resource.data.eventId == resource.data.eventId
        && validShortId(request.resource.data.eventId)
        && resource.data.checkedIn == false
        && resource.data.checkInTime == null
        && request.resource.data.checkedIn == true
        && request.resource.data.checkInTime == request.time
        && validPerformedBy(request.resource.data.checkedInBy)
        && request.resource.data.updatedAt == request.time;
    }

    function isCheckInUndoUpdate(registrationId) {
      return checkInCompletionChangedKeysOnly()
        && request.resource.data.registrationId == registrationId
        && request.resource.data.eventId == resource.data.eventId
        && validShortId(request.resource.data.eventId)
        && resource.data.checkedIn == true
        && resource.data.checkInTime is timestamp
        && resource.data.checkedInBy != null
        && request.resource.data.checkedIn == false
        && request.resource.data.checkInTime == null
        && request.resource.data.checkedInBy == null
        && request.resource.data.updatedAt == request.time;
    }

    // The allowlist is bootstrapped in the Firebase Console. Client code can
    // never create, update, or delete it.
    match /settings/accessControl {
      allow get: if isApprovedAdmin();
      allow list, create, update, delete: if false;
    }

    match /events/{eventId} {
      allow read: if isApprovedAdmin();
      allow create: if isApprovedAdmin()
        && isValidEvent(request.resource.data, eventId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isApprovedAdmin()
        && isValidEvent(request.resource.data, eventId)
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
      allow delete: if isApprovedAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if isApprovedAdmin();
      allow create: if isApprovedAdmin()
        && isValidRegistration(request.resource.data, registrationId)
        && request.resource.data.checkedIn == false
        && request.resource.data.checkInTime == null
        && request.resource.data.checkedInBy == null
        && (hasNoTicketAssigned(request.resource.data) || hasImportedTicketCode(request.resource.data))
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if isApprovedAdmin()
        && (
          isCheckInCompletionUpdate(registrationId)
          || isCheckInUndoUpdate(registrationId)
          || (
            isValidRegistration(request.resource.data, registrationId)
            && request.resource.data.updatedAt == request.time
            && (
              isRegistrationDetailsUpdate()
              || isTicketAssignmentUpdate()
              || isTicketUnassignmentUpdate()
            )
          )
        );
      allow delete: if isApprovedAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isApprovedAdmin();
      allow create: if isApprovedAdmin()
        && (
          (
            request.resource.data.action in ['checkin.complete', 'checkin.undo']
            && isValidRegistrationAuditLog(request.resource.data, logId)
            && matchesRegistrationMutation(request.resource.data)
          )
          || (isValidEventAuditLog(request.resource.data, logId) && matchesEventMutation(request.resource.data))
          || (isValidRegistrationAuditLog(request.resource.data, logId) && matchesRegistrationMutation(request.resource.data))
          || (isValidRegistrationAuditLog(request.resource.data, logId) && matchesDuplicateCheckInAttempt(request.resource.data))
        );
      allow update, delete: if false;
    }

    // Reserved collections remain unavailable until their schemas and rules
    // are implemented and tested.
    match /tickets/{documentId} {
      allow read, write: if false;
    }

    match /checkIn/{documentId} {
      allow read, write: if false;
    }

    match /communications/{documentId} {
      allow read, write: if false;
    }

    match /aiDrafts/{documentId} {
      allow read, write: if false;
    }

    match /settings/{documentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
